# ============================================================
# TransparentGuard — root .gitignore
# Keeps Replit workspace files out of the product repo.
# ============================================================

# Replit workspace artifacts (separate products, not TG code)
artifacts/
attached_assets/
demo-video/
recordings/
sources-video/
screenshots/
scripts/
lib/

# Replit config / agent memory
.replit
replit.md
.agents/

# Python workspace
main.py
pyproject.toml
uv.lock
__pycache__/
*.pyc
.venv/

# Node / pnpm
node_modules/
pnpm-lock.yaml
pnpm-workspace.yaml
package.json
.pnpm-store/

# TypeScript build output (per-package dist/ committed only where intentional)
*.tsbuildinfo

# Env files
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
