{
  "name": "@transparentguard/runtime",
  "version": "0.1.1",
  "description": "TransparentGuard Runtime — AI policy enforcement engine implementing the TransparentGuard Policy Spec (TPS) v1.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit"
  },
  "keywords": [
    "ai",
    "policy",
    "compliance",
    "llm",
    "guardrails",
    "hipaa",
    "gdpr",
    "security",
    "tps",
    "transparentguard"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/transparentguard/runtime"
  },
  "homepage": "https://transparentguard.com"
}
