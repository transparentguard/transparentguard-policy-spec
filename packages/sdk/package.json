{
  "name": "@transparentguard/sdk",
  "version": "0.1.0",
  "description": "TransparentGuard SDK — lazy-init TypeScript wrapper for @transparentguard/runtime. Drop-in policy enforcement with zero boilerplate.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit"
  },
  "keywords": [
    "ai",
    "policy",
    "compliance",
    "llm",
    "guardrails",
    "openai",
    "anthropic",
    "hipaa",
    "gdpr",
    "tps",
    "transparentguard",
    "sdk"
  ],
  "dependencies": {
    "@transparentguard/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT WITH Commons-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/transparentguard/sdk"
  },
  "homepage": "https://transparentguard.dev"
}
