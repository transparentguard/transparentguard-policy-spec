{
  "name": "@transparentguard/runtime-oem",
  "version": "0.1.0",
  "description": "TransparentGuard OEM Runtime — white-label build of the TransparentGuard enforcement engine with usage reporting for embedded distribution",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit"
  },
  "dependencies": {
    "@transparentguard/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "~5.9.3"
  },
  "engines": { "node": ">=18.0.0" },
  "license": "MIT WITH Commons-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/transparentguard/runtime"
  }
}
